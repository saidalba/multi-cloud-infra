# Copy to terraform.tfvars and fill in your values.
# Auth itself is NOT set here -- it comes from the default AWS credential chain
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars, ~/.aws/credentials, SSO).

instance_name       = "aws-ubuntu-arm"
region              = "us-east-1"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Graviton (ARM64) free-tier-eligible instance type.
instance_shape = "t4g.micro"

tags = {
  environment = "dev"
  managed_by  = "terraform"
}
