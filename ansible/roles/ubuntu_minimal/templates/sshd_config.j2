# Managed by Ansible - ubuntu_minimal role. Do not edit by hand.
Port {{ ssh_port }}
PasswordAuthentication no
PermitRootLogin no
PermitEmptyPasswords no
PubkeyAuthentication yes
MaxAuthTries 3
ClientAliveInterval {{ ssh_client_alive_interval }}
ClientAliveCountMax {{ ssh_client_alive_count_max }}

# X11Forwarding is intentionally left unset here -- Ubuntu's stock
# sshd_config already sets it to "yes", and this role doesn't override that.

# Modern, broadly-compatible algorithms only. Any OpenSSH client from the
# last several years (macOS/Linux defaults included) supports these; this
# restricts transport-layer crypto, not which key types can authenticate,
# so existing ed25519/RSA private keys keep working unchanged.
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,ecdh-sha2-nistp521
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
